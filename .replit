modules = ["nodejs-20"]
[nix]
channel = "stable-23_11"

[deployment]
run = ["sh", "-c", "cd backend && npm run build && node dist/index.js"]
deploymentTarget = "autoscale"
build = ["sh", "-c", "cd frontend && npm install --include=dev && npm run build"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx src/index.ts"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
