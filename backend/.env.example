# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aprisys

# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5000

# ── Auth ─────────────────────────────────────────
JWT_SECRET=change-me-32-char-minimum-secret-key
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=different-32-char-secret-for-refresh
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Anthropic AI ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Resend (email) ───────────────────────────────
RESEND_API_KEY=re_placeholder
EMAIL_FROM=Aprisys <noreply@aprisys.com>

# ── Twilio (SMS) ─────────────────────────────────
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_FROM_NUMBER=+1234567890

# ── Paystack ─────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_placeholder
PAYSTACK_PUBLIC_KEY=pk_test_placeholder
PAYSTACK_WEBHOOK_SECRET=whsec_placeholder
PAYSTACK_STANDARD_PLAN_CODE=PLN_placeholder
PAYSTACK_PRO_PLAN_CODE=PLN_placeholder
PAYSTACK_BROKER_PLAN_CODE=PLN_placeholder

# ── Replit Object Storage ────────────────────────
REPLIT_OBJECT_STORE_BUCKET=aprisys-documents
